<?xml version="1.0"?>
<!--
  Per-node cluster + macros config for shard 1. Mounted at
  /etc/clickhouse-server/config.d/cluster.xml.

  `macros` are interpolated into ReplicatedMergeTree's
  `'/clickhouse/tables/{shard}/{table}', '{replica}'` paths — that's
  how the two nodes know they're replicas of the same logical table.

  To make the existing `oi.oi_minute` / `oi.oi_hour` tables replicated,
  replace `ReplacingMergeTree`/`AggregatingMergeTree` with
  `ReplicatedReplacingMergeTree('/clickhouse/tables/{shard}/oi_minute', '{replica}', ingest_ts)`
  etc. in migrations/001_schema.sql when deploying against this cluster.
-->
<clickhouse>
    <zookeeper>
        <node>
            <host>keeper</host>
            <port>9181</port>
        </node>
    </zookeeper>

    <macros>
        <shard>01</shard>
        <replica>ch1</replica>
        <cluster>oi</cluster>
    </macros>

    <remote_servers>
        <oi>
            <shard>
                <internal_replication>true</internal_replication>
                <replica>
                    <host>clickhouse-1</host>
                    <port>9000</port>
                </replica>
                <replica>
                    <host>clickhouse-2</host>
                    <port>9000</port>
                </replica>
            </shard>
        </oi>
    </remote_servers>

    <distributed_ddl>
        <path>/clickhouse/task_queue/ddl</path>
    </distributed_ddl>
</clickhouse>
